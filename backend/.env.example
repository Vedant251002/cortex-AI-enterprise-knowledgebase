# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
# Only needed if embeddings must live on a different Azure OpenAI resource than chat (e.g. the
# primary resource's region has no quota for the embedding model's SKU). Leave blank to reuse
# the endpoint/key above for embeddings too.
AZURE_OPENAI_EMBEDDING_ENDPOINT=
AZURE_OPENAI_EMBEDDING_API_KEY=

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=kb-chunks

# Azure AI Document Intelligence
AZURE_DOCINTEL_ENDPOINT=https://your-docintel.cognitiveservices.azure.com/
AZURE_DOCINTEL_API_KEY=

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER_NAME=documents

# Azure Cosmos DB
AZURE_COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
AZURE_COSMOS_KEY=
AZURE_COSMOS_DATABASE_NAME=cortex
AZURE_COSMOS_AUDIT_CONTAINER=audit_logs
AZURE_COSMOS_USAGE_CONTAINER=user_usage

# Azure AI Content Safety
AZURE_CONTENT_SAFETY_ENDPOINT=https://your-contentsafety.cognitiveservices.azure.com/
AZURE_CONTENT_SAFETY_KEY=

# Azure Key Vault (production path). Leave blank for local dev - Settings reads every secret
# field above directly from this .env. Set this to make Settings resolve each one from Key
# Vault instead via DefaultAzureCredential, falling back to the .env value on any failure.
AZURE_KEY_VAULT_URL=

# Set true to have every Azure SDK client (OpenAI, Search, Blob, Cosmos, Document Intelligence,
# Content Safety) authenticate via DefaultAzureCredential (managed identity in Azure, `az login`
# locally) instead of the *_api_key/*_account_key/*_key settings above. Off by default.
AZURE_USE_MANAGED_IDENTITY=false

# Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Simulated auth (documented Entra ID upgrade path in README)
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=480

# Cost estimation ($ per 1K tokens) - adjust to your actual negotiated rates
COST_PER_1K_PROMPT_TOKENS=0.00025
COST_PER_1K_COMPLETION_TOKENS=0.002
COST_PER_1K_EMBEDDING_TOKENS=0.00002

# Per-role daily token quotas (§7.3, optional). Leave a value blank for unlimited.
DAILY_TOKEN_QUOTA_ADMIN=
DAILY_TOKEN_QUOTA_ANALYST=50000
DAILY_TOKEN_QUOTA_VIEWER=20000
QUOTA_WARNING_THRESHOLD_PCT=0.8
